# Genesys Cloud OAuth Credentials - Example
# Copy this file to .env and fill in your actual values

# Genesys Cloud Provider Credentials (using Terraform variables)
TF_VAR_genesyscloud_oauthclient_id=your-client-id-here
TF_VAR_genesyscloud_oauthclient_secret=your-client-secret-here
TF_VAR_genesyscloud_region=your-region-here

# Terraform Variables for Resources
TF_VAR_integration_id=your-integration-id-here
TF_VAR_api_base_url=https://api.example.com
TF_VAR_environment=your-environment-here
TF_VAR_region=your-region-here
